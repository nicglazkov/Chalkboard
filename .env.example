# Copy this file to .env and fill in your keys
# .env is gitignored — never commit it

# Required
ANTHROPIC_API_KEY=

# TTS backend: kokoro (default, Linux/Apple Silicon only), openai, elevenlabs
TTS_BACKEND=openai

# Only needed for the selected TTS backend
OPENAI_API_KEY=
ELEVENLABS_API_KEY=

# Optional overrides
# MANIM_QUALITY=medium          # low | medium | high
# DEFAULT_EFFORT=medium         # low | medium | high
# DEFAULT_AUDIENCE=intermediate # beginner | intermediate | expert
# DEFAULT_TONE=casual           # casual | formal | socratic
# DEFAULT_THEME=chalkboard      # chalkboard | light | colorful
# OUTPUT_DIR=./output
# CHECKPOINT_DB=pipeline_state.db
